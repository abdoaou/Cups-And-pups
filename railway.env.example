# Railway → NodeAPI service variables (Supabase Postgres)
# Copy to railway.env locally or paste into Railway dashboard. Never commit real secrets.

NODE_ENV=production

JWT_SECRET=your-long-random-secret
JWT_REFRESH_SECRET=your-long-random-refresh-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DB_CONNECTION_LIMIT=10
DB_SSL=true

CORS_ORIGINS=*
RATE_LIMIT_MAX=300
